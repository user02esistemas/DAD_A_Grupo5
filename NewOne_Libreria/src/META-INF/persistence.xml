<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2"
    xmlns="http://xmlns.jcp.org/xml/ns/persistence"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence
                        http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">

    <persistence-unit name="Grupo05_DDA_PAF" transaction-type="RESOURCE_LOCAL">

        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <class>entidades.Productos</class>
        <class>entidades.DetallePedido</class>
        <class>entidades.Empleados</class>
        <class>entidades.Servicios</class>
        <class>entidades.Pagos</class>
        <class>entidades.Citas</class>
        <class>entidades.Pedidos</class>
        <class>entidades.Clientes</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>

            <!-- Driver SQL Server -->
            <property name="javax.persistence.jdbc.driver"
                      value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>

            <!-- Conexión a SQL Server -->
            <property name="javax.persistence.jdbc.url"
                      value="jdbc:sqlserver://localhost\\SQLEXPRESS;databaseName=Grupo05_DDA_PAF"/>

            <!-- Usuario -->
            <property name="javax.persistence.jdbc.user"
                      value="sa"/>

            <!-- Contraseña -->
            <property name="javax.persistence.jdbc.password"
                      value="dbo"/>

            <!-- EclipseLink -->
            <property name="eclipselink.weaving" value="false"/>
            <property name="eclipselink.logging.level" value="FINE"/>

        </properties>

    </persistence-unit>

</persistence>